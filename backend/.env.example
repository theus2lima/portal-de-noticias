# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Use the SERVICE ROLE key — this key is server-side only, never expose to clients
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Redis / Upstash ──────────────────────────────────────────────────────────
# Standard Redis:  redis://localhost:6379
# Upstash (TLS):   rediss://default:password@your-endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL=60            # seconds

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=120      # max requests per window per IP
RATE_LIMIT_WINDOW=1 minute

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all (not recommended in prod).
CORS_ORIGINS=https://your-frontend.vercel.app

# ─── Ops Dashboard ────────────────────────────────────────────────────────────
# Secret key required in x-ops-key header to access /ops/* endpoints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPS_SECRET=change-this-to-a-strong-random-secret
